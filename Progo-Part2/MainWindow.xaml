<Window x:Class="Progo_Part2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Progo_Part2"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Window.Resources>
        <Style x:Key="ChatBubbleUser" TargetType="Border">
            <Setter Property="Background" Value="#3498DB"/>
            <Setter Property="CornerRadius" Value="15"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Margin" Value="100,5,20,5"/>
        </Style>

        <Style x:Key="ChatBubbleBot" TargetType="Border">
            <Setter Property="Background" Value="#ECF0F1"/>
            <Setter Property="CornerRadius" Value="15"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Margin" Value="20,5,100,5"/>
        </Style>

        <Style x:Key="SendButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#27AE60"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2ECC71"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="HistoryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#9B59B6"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="15,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#8E44AD"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header with ASCII Art and Profile Picture -->
        <Border Grid.Row="0" Background="#34495E" Padding="15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- ASCII Art and Title (Left Side) -->
                <StackPanel Grid.Column="0">
                    <TextBlock Text="🛡️ CYBERSECURITY AWARENESS CHATBOT 🛡️" 
                               FontSize="20" FontWeight="Bold" 
                               Foreground="White" HorizontalAlignment="Center"/>
                    <TextBlock FontFamily="Consolas" FontSize="10" 
                               Foreground="#7F8C8D" HorizontalAlignment="Center"
                               Text="═══════════════════════════════════════════════════════════════"/>
                    <TextBlock FontFamily="Consolas" FontSize="9" 
                               Foreground="#BDC3C7" HorizontalAlignment="Center">
                        <Run Text="  ██████╗██╗   ██╗██████╗ ███████╗██████╗ ███████╗ ██████╗ "/>
                        <LineBreak/>
                        <Run Text=" ██╔════╝╚██╗ ██╔╝██╔══██╗██╔════╝██╔══██╗██╔════╝██╔════╝ "/>
                        <LineBreak/>
                        <Run Text=" ██║      ╚████╔╝ ██████╔╝█████╗  ██████╔╝███████╗██║  ███╗"/>
                        <LineBreak/>
                        <Run Text=" ██║       ╚██╔╝  ██╔══██╗██╔══╝  ██╔══██╗╚════██║██║   ██║"/>
                        <LineBreak/>
                        <Run Text=" ╚██████╗   ██║   ██████╔╝███████╗██║  ██║███████║╚██████╔╝"/>
                        <LineBreak/>
                        <Run Text="  ╚═════╝   ╚═╝   ╚═════╝ ╚══════╝╚═╝  ╚═╝╚══════╝ ╚═════╝ "/>
                    </TextBlock>
                    <TextBlock Text="Your Security Companion | Stay Safe Online!" 
                               FontSize="11" Foreground="#BDC3C7" 
                               HorizontalAlignment="Center" Margin="0,5,0,0"/>
                </StackPanel>

                <!-- User Profile Picture (Right Side) -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right">
                    <Border Width="60" Height="60" 
                            CornerRadius="30" 
                            Background="#3498DB"
                            BorderBrush="White" 
                            BorderThickness="2"
                            Cursor="Hand"
                            MouseLeftButtonDown="ProfilePicture_Click">
                        <Grid>
                            <Image x:Name="ProfileImage" 
                                   Width="56" Height="56" 
                                   Stretch="UniformToFill"
                                   Visibility="Collapsed"/>
                            <TextBlock x:Name="ProfileIcon" 
                                       Text="👤" 
                                       FontSize="35" 
                                       HorizontalAlignment="Center" 
                                       VerticalAlignment="Center"
                                       Foreground="White"
                                       Visibility="Visible"/>
                        </Grid>
                    </Border>
                    <TextBlock Text="Click to change" 
                               FontSize="9" 
                               Foreground="#BDC3C7" 
                               HorizontalAlignment="Center" 
                               Margin="0,3,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Chat Display Area -->
        <Border Grid.Row="1" Background="#ECF0F1">
            <ScrollViewer x:Name="ChatScrollViewer" 
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel x:Name="ChatStackPanel" Margin="10" Orientation="Vertical"/>
            </ScrollViewer>
        </Border>

        <!-- Input Area -->
        <Border Grid.Row="2" Background="#34495E" Padding="15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="InputTextBox" 
                         Grid.Column="0"
                         Height="50"
                         FontSize="14"
                         Padding="10"
                         Background="White"
                         Foreground="#2C3E50"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         KeyDown="InputTextBox_KeyDown"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="10,0,0,0">
                    <Button x:Name="SendButton" 
                            Content="SEND" 
                            Style="{StaticResource SendButtonStyle}"
                            Height="50"
                            Width="80"
                            Click="SendButton_Click"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="10,0,0,0">
                    <Button x:Name="ViewHistoryButton" 
                            Content="HISTORY" 
                            Style="{StaticResource HistoryButtonStyle}"
                            Height="50"
                            Width="120"
                            Click="ViewHistoryButton_Click"
                            Margin="0,0,5,0"/>
                    <Button x:Name="ClearButton" 
                            Content="CLEAR" 
                            Background="#E74C3C"
                            Foreground="White"
                            FontSize="14"
                            FontWeight="Bold"
                            Padding="15,10"
                            Height="50"
                            Width="80"
                            Cursor="Hand"
                            Click="ClearButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
